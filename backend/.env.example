# ---- Database ----
DATABASE_URL=postgresql+psycopg2://helpdeck:helpdeck@localhost:5432/helpdeck

# ---- LLM (OpenAI-compatible) ----
# Default: Groq (free, fast). Get a key at https://console.groq.com/keys
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# To switch to DeepSeek instead, use:
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ---- Platform integration ----
# Shared secret a trusted partner (e.g. Perico) sends in the X-Platform-Key
# header to provision tenants server-to-server. Generate with:
#   python -c "import secrets; print('plat_'+secrets.token_urlsafe(32))"
PLATFORM_API_KEY=your_platform_key_here

# ---- Embeddings (local, free via fastembed) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---- App ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
CORS_ORIGINS=*

# ---- Stripe billing (standalone global USD) ----
# Test-mode keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` (CLI) or the dashboard webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs (create recurring USD prices in the dashboard)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
# Where Stripe returns the user after checkout (standalone dashboard)
BILLING_SUCCESS_URL=http://localhost:5173/?checkout=success
BILLING_CANCEL_URL=http://localhost:5173/?checkout=cancelled
