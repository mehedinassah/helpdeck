# ---- Database ----
DATABASE_URL=postgresql+psycopg2://helpdeck:helpdeck@localhost:5432/helpdeck

# ---- LLM (OpenAI-compatible) ----
# Default: Groq (free, fast). Get a key at https://console.groq.com/keys
LLM_API_KEY=your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# To switch to DeepSeek instead, use:
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat

# ---- Embeddings (local, free via fastembed) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ---- App ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=5
CORS_ORIGINS=*
